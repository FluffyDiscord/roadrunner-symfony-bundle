{
    "name" : "fluffydiscord/roadrunner-symfony-bundle",
    "description" : "Roadrunner runtime for Symfony",
    "license" : "MIT",
    "type" : "library",
    "authors" : [
        {
            "name" : "Rostislav Kaleta",
            "email" : "rostislavkaleta@gmail.com"
        }
    ],
    "require" : {
        "php" : ">=8.4",
        "nyholm/psr7" : "^1.8",
        "spiral/roadrunner" : "^v2025 || ^3",
        "symfony/dependency-injection" : "^7.4 || ^8",
        "symfony/http-kernel" : "^7.4 || ^8",
        "symfony/psr-http-message-bridge" : "^7.4 || ^8",
        "symfony/runtime" : "^7.4 || ^8",
        "symfony/framework-bundle" : "^7.4 || ^8",
        "symfony/event-dispatcher" : "^7.4 || ^8",
        "symfony/expression-language" : "^7.4 || ^8",
        "spiral/roadrunner-worker" : "^v3",
        "spiral/roadrunner-http" : "^v4",
        "spiral/roadrunner-cli" : "^v2",
        "spiral/roadrunner-jobs": "^4.7"
    },
    "minimum-stability" : "dev",
    "prefer-stable" : true,
    "autoload" : {
        "files" : [
            "src/Resources/services_resetter_polyfill.php"
        ],
        "psr-4" : {
            "FluffyDiscord\\RoadRunnerBundle\\" : "src/"
        }
    },
    "autoload-dev" : {
        "psr-4" : {
            "FluffyDiscord\\RoadRunnerBundle\\Tests\\" : "tests/"
        },
        "symfony/runtime" : true
    },
    "config" : {
        "allow-plugins" : {
            "php-http/discovery": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        }
    },
    "require-dev" : {
        "sentry/sentry-symfony" : "^5",
        "phpunit/phpunit" : "^13",
        "symfony/mime" : "^7.4 || ^8",
        "roadrunner-php/centrifugo" : "^v2",
        "spiral/roadrunner-kv" : "^v4",
        "temporal/sdk" : "^2.16",
        "symfony/serializer" : "^7.4 || ^8",
        "symfony/property-access" : "^7.4 || ^8",
        "roadrunner-php/lock" : "^1.0",
        "symfony/lock" : "^7.4 || ^8",
        "roadrunner-php/symfony-lock-driver" : "^1.1",
        "phpstan/phpstan" : "^2.1",
        "phpstan/phpstan-symfony" : "^2.0",
        "phpstan/extension-installer": "^1.4"
    },
    "suggest" : {
        "temporal/sdk" : "Enables the Temporal.io worker, interceptors and profiler data collector",
        "ext-igbinary" : "Smaller, faster binary serializer for the Jobs message-bus; used automatically when present, otherwise the native serializer is used.",
        "symfony/serializer" : "Optional JSON-based serializer for the Jobs message-bus (interoperable payloads). The default native serializer requires no extra dependencies.",
        "roadrunner-php/symfony-lock-driver" : "Exposes RoadRunner distributed locks as a Symfony LockFactory / PersistingStoreInterface (pulls in roadrunner-php/lock + symfony/lock)."
    }
}
